# ==========================================================================
# App
# ==========================================================================
APP_NAME="Mob API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Lagos
APP_URL=https://api.mob.app

# ==========================================================================
# Database
# ==========================================================================
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=mob_production
DB_USERNAME=
DB_PASSWORD=

# ==========================================================================
# Cache & Queue (Production should use Redis)
# ==========================================================================
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==========================================================================
# Sanctum
# ==========================================================================
SANCTUM_STATEFUL_DOMAINS=

# ==========================================================================
# Payment Gateways
# ==========================================================================
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# ==========================================================================
# Firebase
# ==========================================================================
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# ==========================================================================
# Logging
# ==========================================================================
LOG_CHANNEL=daily
LOG_LEVEL=warning

# ==========================================================================
# Mail (for future use)
# ==========================================================================
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mob.app
MAIL_FROM_NAME="Mob"

# ==========================================================================
# OTP Bypass (MUST be false in production)
# ==========================================================================
OTP_BYPASS_ENABLED=false
OTP_BYPASS_CODE=123456
